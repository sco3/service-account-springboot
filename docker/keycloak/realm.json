{
  "realm": "service-accounts",
  "enabled": true,

  "roles": {
    "realm": [
      {
        "name": "admin"
      },
      {
        "name": "user"
      }
    ]
  },

  "clients": [
    {
      "clientId": "service-api",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "secret": "service-api-secret",

      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,

      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,

      "redirectUris": [],
      "webOrigins": [],

      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",

      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],

      "realmRoles": [
        "admin"
      ]
    }
  ]
}